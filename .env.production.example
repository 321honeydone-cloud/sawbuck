# Sawbuck AI - production environment. Copy to your host's env settings.

# Cloud brain (required for the agents, vision, pricing research)
ANTHROPIC_API_KEY=sk-ant-...
AI_PROVIDER=claude
CLAUDE_TEXT_MODEL=claude-sonnet-4-6
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=4096

# Auth (REQUIRED: set a long random AUTH_TOKEN, this signs the login cookie)
AUTH_TOKEN=replace-with-a-long-random-string
APP_PINS=your-owner-pin

# Data + storage on a mounted persistent volume so they survive redeploys
DATABASE_URL=file:/data/sawbuck.db
UPLOAD_DIR=/data/uploads
# Shared learning log on the SAME persistent volume, so contractors' quotes
# accumulate across redeploys instead of resetting to the shipped seed.
SAWBUCK_MEMORY_PATH=/data/SAWBUCK_MEMORY.md

# Scheduled rate-book fill (set a long random string, use as x-cron-key)
CRON_SECRET=replace-with-a-long-random-string

# Shared-brain sync. Set the SAME value here (on Render) and in your local
# .env.sync so the push script can merge the learning log both ways. Leave unset
# to disable the /api/memory/sync endpoint entirely.
SYNC_SECRET=replace-with-a-long-random-string
